{ passages:[{id:EPIC_0001,meta:{author:Epictetus,book:Enchiridion},emotionCore:none,emotionExtended:[],lines:[어떤 것은 내게 달려 있고,어떤 것은 내게 달려 있지 않다,생각과 판단과 의지는 내 쪽에 있지만,몸과 평판과 결과는 완전히 내 것이 아니다,이 둘을 자꾸 뒤섞을수록 마음은 흔들리고,구분할수록 조금씩 평온해진다]},{id:EPIC_0002,meta:{author:Epictetus,book:Enchiridion},emotionCore:none,emotionExtended:[],lines:[사람을 괴롭히는 것은 사건 자체가 아니라,그 사건에 대해 스스로 내린 판단일 때가 많다,같은 일을 두고도 마음이 다르게 반응하는 이유가 여기에 있다,그래서 흔들리는 순간마다,무슨 일이 일어났는지보다 그것을 어떻게 받아들이는지를 보게 된다]}]}
